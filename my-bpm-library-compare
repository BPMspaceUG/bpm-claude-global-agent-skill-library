#!/usr/bin/env bash
#
# my-bpm-library-compare - Compare local my-bpm-items with the Git repository
#
# Usage:
#   my-bpm-library-compare                     Compare all my-bpm-items
#   my-bpm-library-compare --dry-run           Show what --repair would do
#   my-bpm-library-compare --repair            Sync missing items after confirmation
#   my-bpm-library-compare --only-skills       Compare only skills
#   my-bpm-library-compare --only-agents       Compare only agents
#   my-bpm-library-compare --only-commands     Compare only commands
#   my-bpm-library-compare --only-runbooks     Compare only runbooks
#   my-bpm-library-compare --verbose           Show detailed output
#   my-bpm-library-compare --version           Show version
#   my-bpm-library-compare --help              Show this help
#
# Requires: git, diff

set -euo pipefail

VERSION="260315-1200"
REPO_NAME="bpm-claude-global-agent-skill-library"
REPO_DIR="$HOME/$REPO_NAME"

# Source shared library
# shellcheck source=lib.sh
source "$(dirname "$(readlink -f "$0")")/lib.sh"

# Defaults
DRY_RUN=0
VERBOSE=0
REPAIR=0
ONLY_SKILLS=0
ONLY_AGENTS=0
ONLY_COMMANDS=0
ONLY_RUNBOOKS=0

# Categories to compare
CATEGORIES=(skills agents commands runbooks)

# Result tracking
LOCAL_ONLY_ITEMS=()
REPO_ONLY_ITEMS=()
MODIFIED_ITEMS=()
IDENTICAL_COUNT=0

show_help() {
  echo "my-bpm-library-compare v$VERSION - Compare local vs repo my-bpm-items"
  echo ""
  echo "Usage:"
  echo "  my-bpm-library-compare                     Compare all my-bpm-items"
  echo "  my-bpm-library-compare --dry-run           Show what --repair would do"
  echo "  my-bpm-library-compare --repair            Sync missing items after confirmation"
  echo "  my-bpm-library-compare --only-skills       Compare only skills"
  echo "  my-bpm-library-compare --only-agents       Compare only agents"
  echo "  my-bpm-library-compare --only-commands     Compare only commands"
  echo "  my-bpm-library-compare --only-runbooks     Compare only runbooks"
  echo "  my-bpm-library-compare --verbose           Show detailed output"
  echo "  my-bpm-library-compare --version           Show version"
  echo "  my-bpm-library-compare --help              Show this help"
  echo ""
  echo "Symbols:"
  echo "  L  local only   — exists locally but not in repo"
  echo "  R  repo only    — exists in repo but not locally"
  echo "  ~  modified     — exists in both but content differs"
  echo "  =  identical    — same content (shown with --verbose)"
}

# Parse arguments
# shellcheck disable=SC2034 # VERBOSE is used by log_verbose in lib.sh
for arg in "$@"; do
  case "$arg" in
    --dry-run)       DRY_RUN=1 ;;
    --verbose)       VERBOSE=1 ;;
    --repair)        REPAIR=1 ;;
    --only-skills)   ONLY_SKILLS=1 ;;
    --only-agents)   ONLY_AGENTS=1 ;;
    --only-commands) ONLY_COMMANDS=1 ;;
    --only-runbooks) ONLY_RUNBOOKS=1 ;;
    -v|--version)    echo "my-bpm-library-compare v$VERSION"; exit 0 ;;
    -h|--help)       show_help; exit 0 ;;
    *)               echo "Unknown option: $arg"; show_help; exit 1 ;;
  esac
done

# Determine which categories to process
if [[ "$ONLY_SKILLS" -eq 1 ]] || [[ "$ONLY_AGENTS" -eq 1 ]] || [[ "$ONLY_COMMANDS" -eq 1 ]] || [[ "$ONLY_RUNBOOKS" -eq 1 ]]; then
  CATEGORIES=()
  [[ "$ONLY_SKILLS" -eq 1 ]] && CATEGORIES+=("skills")
  [[ "$ONLY_AGENTS" -eq 1 ]] && CATEGORIES+=("agents")
  [[ "$ONLY_COMMANDS" -eq 1 ]] && CATEGORIES+=("commands")
  [[ "$ONLY_RUNBOOKS" -eq 1 ]] && CATEGORIES+=("runbooks")
fi

# Require commands
require_commands "git" "diff"

# Determine local directory
LOCAL_DIR="$(get_target_dir)"

log_verbose "Local directory: $LOCAL_DIR"
log_verbose "Repo directory:  $REPO_DIR"
log_verbose "Categories: ${CATEGORIES[*]}"

echo "my-bpm-library-compare v$VERSION"
echo ""

# Verify repo exists
if [[ ! -d "$REPO_DIR/.git" ]]; then
  echo "ERROR: Repository not found at $REPO_DIR"
  echo "Run 'my-bpm-library-pull' first to clone the repository."
  exit 1
fi

# Verify my/ directory exists in repo
if [[ ! -d "$REPO_DIR/my" ]]; then
  echo "No my/ directory found in repository."
  echo "Nothing to compare."
  exit 0
fi

# Compare each category
for category in "${CATEGORIES[@]}"; do
  LOCAL_CAT_DIR="$LOCAL_DIR/$category"
  REPO_CAT_DIR="$REPO_DIR/my/$category"

  log_verbose "Comparing category: $category"
  log_verbose "  Local: $LOCAL_CAT_DIR"
  log_verbose "  Repo:  $REPO_CAT_DIR"

  # Collect item names from both sides
  declare -A local_items=()
  declare -A repo_items=()

  if [[ "$category" == "skills" ]]; then
    # Skills are directories
    if [[ -d "$LOCAL_CAT_DIR" ]]; then
      for item in "$LOCAL_CAT_DIR"/my-*/; do
        [[ -d "$item" ]] || continue
        local_items["$(basename "$item")"]=1
      done
    fi
    if [[ -d "$REPO_CAT_DIR" ]]; then
      for item in "$REPO_CAT_DIR"/my-*/; do
        [[ -d "$item" ]] || continue
        repo_items["$(basename "$item")"]=1
      done
    fi
  else
    # Agents, commands, runbooks are .md files
    if [[ -d "$LOCAL_CAT_DIR" ]]; then
      for item in "$LOCAL_CAT_DIR"/my-*.md; do
        [[ -f "$item" ]] || continue
        local_items["$(basename "$item")"]=1
      done
    fi
    if [[ -d "$REPO_CAT_DIR" ]]; then
      for item in "$REPO_CAT_DIR"/my-*.md; do
        [[ -f "$item" ]] || continue
        repo_items["$(basename "$item")"]=1
      done
    fi
  fi

  # Merge all item names
  declare -A all_items=()
  for name in "${!local_items[@]}"; do all_items["$name"]=1; done
  for name in "${!repo_items[@]}"; do all_items["$name"]=1; done

  # Compare each item
  for item_name in $(echo "${!all_items[@]}" | tr ' ' '\n' | sort); do
    item_key="$category/$item_name"
    in_local="${local_items[$item_name]:-}"
    in_repo="${repo_items[$item_name]:-}"

    if [[ -n "$in_local" ]] && [[ -z "$in_repo" ]]; then
      echo "  L  $item_key"
      LOCAL_ONLY_ITEMS+=("$item_key")
    elif [[ -z "$in_local" ]] && [[ -n "$in_repo" ]]; then
      echo "  R  $item_key"
      REPO_ONLY_ITEMS+=("$item_key")
    else
      # Both exist — compare content
      if [[ "$category" == "skills" ]]; then
        if ! diff -rq "$LOCAL_CAT_DIR/$item_name" "$REPO_CAT_DIR/$item_name" > /dev/null 2>&1; then
          echo "  ~  $item_key"
          MODIFIED_ITEMS+=("$item_key")
        else
          ((IDENTICAL_COUNT++)) || true
          log_verbose "  =  $item_key"
        fi
      else
        if ! diff -q "$LOCAL_CAT_DIR/$item_name" "$REPO_CAT_DIR/$item_name" > /dev/null 2>&1; then
          echo "  ~  $item_key"
          MODIFIED_ITEMS+=("$item_key")
        else
          ((IDENTICAL_COUNT++)) || true
          log_verbose "  =  $item_key"
        fi
      fi
    fi
  done

  # Clean up associative arrays for next iteration
  unset local_items repo_items all_items
done

# Summary
echo ""
echo "Summary:"
echo "  Local only:  ${#LOCAL_ONLY_ITEMS[@]}"
echo "  Repo only:   ${#REPO_ONLY_ITEMS[@]}"
echo "  Modified:    ${#MODIFIED_ITEMS[@]}"
echo "  Identical:   $IDENTICAL_COUNT"

TOTAL_DIFF=$(( ${#LOCAL_ONLY_ITEMS[@]} + ${#REPO_ONLY_ITEMS[@]} + ${#MODIFIED_ITEMS[@]} ))

if [[ "$TOTAL_DIFF" -eq 0 ]]; then
  echo ""
  echo "Everything is in sync."
  exit 0
fi

# Repair mode
if [[ "$REPAIR" -eq 1 ]] || [[ "$DRY_RUN" -eq 1 ]]; then
  echo ""
  echo "Repair plan:"

  if [[ ${#REPO_ONLY_ITEMS[@]} -gt 0 ]]; then
    echo "  Pull from repo to local:"
    for item in "${REPO_ONLY_ITEMS[@]}"; do
      echo "    <- $item"
    done
  fi

  if [[ ${#LOCAL_ONLY_ITEMS[@]} -gt 0 ]]; then
    echo "  Push from local to repo:"
    for item in "${LOCAL_ONLY_ITEMS[@]}"; do
      echo "    -> $item"
    done
  fi

  if [[ ${#MODIFIED_ITEMS[@]} -gt 0 ]]; then
    echo "  Modified (content differs — use pull --force or push --force):"
    for item in "${MODIFIED_ITEMS[@]}"; do
      echo "    !! $item"
    done
  fi

  if [[ "$DRY_RUN" -eq 1 ]]; then
    echo ""
    echo "DRY RUN - No changes made"
    exit 0
  fi

  # Only proceed with repair if there are items to sync
  REPAIRABLE=$(( ${#REPO_ONLY_ITEMS[@]} + ${#LOCAL_ONLY_ITEMS[@]} ))
  if [[ "$REPAIRABLE" -eq 0 ]]; then
    echo ""
    echo "Nothing to repair automatically. Modified items require manual resolution."
    echo "  Use 'my-bpm-library-pull --force' or 'my-bpm-library-push --force' to resolve."
    exit 0
  fi

  # Ask user what to do
  echo ""
  echo "Repair options:"
  echo "  pull  — Pull missing items from repo to local"
  echo "  push  — Push missing items from local to repo"
  echo "  both  — Pull first, then push"
  echo "  skip  — Do nothing"
  echo ""
  read -p "Choose [pull/push/both/skip]: " -r REPAIR_CHOICE </dev/tty 2>/dev/null || REPAIR_CHOICE="skip"

  DO_PULL=0
  DO_PUSH=0
  case "$REPAIR_CHOICE" in
    pull) DO_PULL=1 ;;
    push) DO_PUSH=1 ;;
    both) DO_PULL=1; DO_PUSH=1 ;;
    skip|"") echo "Aborted."; exit 0 ;;
    *) echo "Unknown choice: $REPAIR_CHOICE"; exit 1 ;;
  esac

  PULLED=0
  PUSHED=0

  # Pull repo-only items to local
  if [[ "$DO_PULL" -eq 1 ]] && [[ ${#REPO_ONLY_ITEMS[@]} -gt 0 ]]; then
    for item_key in "${REPO_ONLY_ITEMS[@]}"; do
      category="${item_key%%/*}"
      item_name="${item_key#*/}"
      local_path="$LOCAL_DIR/$category/$item_name"
      repo_path="$REPO_DIR/my/$category/$item_name"

      mkdir -p "$LOCAL_DIR/$category"

      if [[ "$category" == "skills" ]]; then
        cp -R "$repo_path" "$local_path"
      else
        cp "$repo_path" "$local_path"
      fi
      echo "  Pulled: $item_key"
      ((PULLED++)) || true
    done
  fi

  # Push local-only items to repo
  if [[ "$DO_PUSH" -eq 1 ]] && [[ ${#LOCAL_ONLY_ITEMS[@]} -gt 0 ]]; then
    for item_key in "${LOCAL_ONLY_ITEMS[@]}"; do
      category="${item_key%%/*}"
      item_name="${item_key#*/}"
      local_path="$LOCAL_DIR/$category/$item_name"
      repo_path="$REPO_DIR/my/$category/$item_name"

      mkdir -p "$REPO_DIR/my/$category"

      if [[ "$category" == "skills" ]]; then
        cp -R "$local_path" "$repo_path"
      else
        cp "$local_path" "$repo_path"
      fi
      echo "  Pushed: $item_key"
      ((PUSHED++)) || true
    done
  fi

  echo ""
  echo "Repair complete."
  echo "  Pulled: $PULLED items"
  echo "  Pushed: $PUSHED items"

  if [[ "$PUSHED" -gt 0 ]]; then
    echo ""
    echo "NOTE: Pushed items are in the repo working tree but not committed."
    echo "  Run 'my-bpm-library-push' to commit and push to remote."
  fi
fi
